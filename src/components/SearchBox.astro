---
import { getCollection, render } from 'astro:content';
import {
  getEntryUrl,
  getTopicTitle,
  isPublished,
  titleFromId,
  type EntryLike
} from '../lib/content';

type SearchEntry = {
  kind: 'article' | 'heading';
  title: string;
  pageTitle: string;
  url: string;
};

const contentEntries = [
  ...(await getCollection('interview', isPublished)),
  ...(await getCollection('notes', isPublished)),
  ...(await getCollection('posts', isPublished))
];

function getSearchTitle(entry: EntryLike & { collection?: string }) {
  if (entry.collection === 'interview') return getTopicTitle(entry as never);
  return entry.data.title ?? titleFromId(entry.id);
}

const searchIndex = (
  await Promise.all(
    contentEntries.map(async (entry) => {
      const pageTitle = getSearchTitle(entry);
      const pageUrl = getEntryUrl(entry);
      const { headings } = await render(entry);
      const headingEntries = headings
        .filter((heading) => heading.depth >= 2 && heading.depth <= 3)
        .map((heading) => ({
          kind: 'heading' as const,
          title: heading.text,
          pageTitle,
          url: `${pageUrl}#${heading.slug}`
        }));

      return [
        {
          kind: 'article' as const,
          title: pageTitle,
          pageTitle,
          url: pageUrl
        },
        ...headingEntries
      ];
    })
  )
).flat();
---

<div class="w-full max-w-[36rem]" aria-label="站内搜索">
  <div class="relative">
    <svg class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-outline w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="search"
      id="site-search"
      placeholder="搜索随笔、知识库..."
      autocomplete="off"
      data-search-input
      class="w-full bg-surface-container-lowest border border-outline-variant rounded-full py-3 pl-12 pr-4 text-body-md text-on-surface focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary transition-all shadow-[0_2px_8px_rgba(0,0,0,0.04)] placeholder:text-outline"
    />
  </div>
  <div class="hidden mt-3 max-h-[26rem] overflow-y-auto overscroll-contain pr-1 text-left" data-search-results aria-live="polite"></div>
</div>

<script define:vars={{ searchIndex }}>
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');

  function clearResults() {
    if (!results) return;
    results.innerHTML = '';
    results.classList.add('hidden');
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function normalizeText(text) {
    return (text ?? '').toLowerCase().replace(/\s+/g, '');
  }

  function isLatinQuery(query) {
    return /^[a-z0-9#+.\-_]+$/i.test(query);
  }

  function rankResult(item, query) {
    const normalizedQuery = normalizeText(query);
    const title = normalizeText(item.title);
    const pageTitle = normalizeText(item.pageTitle);
    const hasExactMatch = title.includes(normalizedQuery) || pageTitle.includes(normalizedQuery);

    if (isLatinQuery(query) && query.length >= 3 && !hasExactMatch) {
      return -1;
    }

    let score = 0;
    if (title.includes(normalizedQuery)) score += 100;
    if (title === normalizedQuery) score += 80;
    if (pageTitle.includes(normalizedQuery)) score += 40;
    if (item.kind === 'article') score += 20;
    if (hasExactMatch) score += 20;
    return score;
  }

  input?.addEventListener('input', async (event) => {
    if (!results) return;

    const query = event.target.value.trim();
    if (query.length < 2) {
      clearResults();
      return;
    }

    results.innerHTML = '<p class="text-label-sm text-on-surface-variant p-4 text-center">检索中...</p>';
    results.classList.remove('hidden');

    const matches = searchIndex
      .map((item) => ({ ...item, score: rankResult(item, query) }))
      .filter((item) => item.score >= 0)
      .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title, 'zh-CN'));

    if (matches.length === 0) {
      results.innerHTML = '<p class="text-label-sm text-on-surface-variant p-4 text-center">没有找到相关标题。</p>';
      return;
    }

    results.innerHTML = matches
      .map((item) => {
        const isHeading = item.kind === 'heading';
        const meta = isHeading ? `${item.pageTitle} / 小标题` : '文章标题';

        return `
          <a class="block p-3 bg-surface-container-lowest border border-surface-variant rounded-lg mb-2 hover:border-secondary transition-colors" href="${item.url}">
            <strong class="text-label-md text-primary block">${escapeHtml(item.title)}</strong>
            <span class="text-label-sm text-on-surface-variant">${escapeHtml(meta)}</span>
          </a>
        `;
      })
      .join('');
  });
</script>
