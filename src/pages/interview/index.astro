---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicCard from '../../components/TopicCard.astro';
import {
  getTopicDescription,
  getTopicTitle,
  getTopicUrl,
  isPublished,
  sortInterviewTopics,
  withBase
} from '../../lib/content';
import { getInterviewTopicIcon } from '../../lib/interview-icons';

const topics = sortInterviewTopics(await getCollection('interview', isPublished));
const topicCards = await Promise.all(
  topics.map(async (topic) => {
    const { headings } = await render(topic);
    return {
      topic,
      questionCount: headings.filter((heading) => heading.depth === 2).length
    };
  })
);

---

<BaseLayout title="面试题" description="高频面试题、追问链路和工程场景总结。">
  <div class="mb-lg">
    <a href={withBase('/')} class="inline-flex items-center gap-2 text-label-md font-medium text-secondary hover:text-on-secondary-fixed-variant transition-colors group">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      返回首页
    </a>
  </div>

  <header class="mb-xl text-center max-w-3xl mx-auto pt-lg">
    <p class="text-label-sm font-medium text-secondary uppercase tracking-widest mb-2">Interview Notes</p>
    <h1 class="text-headline-xxl font-semibold text-primary tracking-tight">面试题复习室</h1>
    <p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto mt-2 leading-relaxed">
      高频面试题、追问链路和工程场景总结，按技术专题分类整理。
    </p>
  </header>

  <section aria-label="面试题专题">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
      {
        topicCards.map(({ topic, questionCount }) => (
          <TopicCard
            title={getTopicTitle(topic)}
            description={getTopicDescription(topic)}
            questionCount={questionCount}
            href={getTopicUrl(topic)}
            icon={getInterviewTopicIcon(topic.id)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
